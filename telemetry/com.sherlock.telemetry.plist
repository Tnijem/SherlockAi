<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sherlock.telemetry</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/tommynijem/Sherlock/venv/bin/python</string>
        <string>/Users/tommynijem/Sherlock/telemetry/agent.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/tommynijem/Sherlock/telemetry</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/tommynijem/Sherlock/logs/telemetry-agent.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/tommynijem/Sherlock/logs/telemetry-agent.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/tommynijem/Sherlock/venv/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
